# Public application URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase: Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# Server-only. Never prefix this key with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Generate independent values with: openssl rand -hex 32
ADMIN_JWT_SECRET=YOUR_64_CHARACTER_HEX_SECRET
CLIENT_JWT_SECRET=YOUR_OTHER_64_CHARACTER_HEX_SECRET

# Stripe test keys for local development; use live keys only in Production.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_PRICE_SPARK=price_REPLACE_ME
STRIPE_PRICE_EMBER=price_REPLACE_ME
STRIPE_PRICE_BLAZE=price_REPLACE_ME
STRIPE_PRICE_INFERNO=price_REPLACE_ME
